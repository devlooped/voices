<rss xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd" version="2.0">
  <channel>
    <title>{{title}}</title>
    <description>{{description}}</description>
    <link>https://github.com/devlooped/voices</link>
    <docs>https://github.com/devlooped/voices</docs>
    <language>{{language}}</language>
    <copyright>Copyright © Kzu</copyright>
    <pubDate>{{pubDate}}</pubDate>
    <lastBuildDate>{{lastBuildDate}}</lastBuildDate>
    <webMaster>{{email}}</webMaster>
    <managingEditor>{{email}}</managingEditor>
    <generator>{{author}}</generator>
    <itunes:author>{{author}}</itunes:author>
    <itunes:subtitle>{{title}}</itunes:subtitle>
    <itunes:summary>{{description}}</itunes:summary>
    <itunes:owner>
      <itunes:name>{{author}}</itunes:name>
      <itunes:email>{{email}}</itunes:email>
    </itunes:owner>
    <itunes:explicit>no</itunes:explicit>
    <itunes:image href="https://{{storage}}.blob.core.windows.net/{{container}}/{{language}}/cover.png" />
    <itunes:category text="Business">
      <itunes:category text="Entrepreneurship" />
    </itunes:category>
    <itunes:category text="Technology" />
    <itunes:category text="News">
      <itunes:category text="Business News" />
    </itunes:category>
  </channel>
</rss>